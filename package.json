{
  "name": "vanilla-core",
  "version": "1.0.0",
  "description": "The minimalist core for modern web engineering. No dependencies, no overhead—just fast, native JavaScript.",
  "keywords": [
    "vanilla",
    "spa",
    "architecture",
    "framework",
    "performance",
    "native-js"
  ],
  "homepage": "https://github.com/Iglesiasleonardo-o/VanillaCore#readme",
  "bugs": {
    "url": "https://github.com/Iglesiasleonardo-o/VanillaCore/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Iglesiasleonardo-o/VanillaCore.git"
  },
  "license": "MIT",
  "author": "Iglesias Leonardo <iglesias@inovitek.com>",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --watch server.js",
    "server:watch": "node --env-file-if-exists=.env --watch server.js",
    "dev": "concurrently 'npm run server:watch' 'npm run tailwindcss:watch'",
    "tailwindcss:watch": "npx @tailwindcss/cli -i ./tailwind/input.css -o ./public/css/style.css --watch"
  },
  "dependencies": {
    "express": "^5.2.1",
    "mongodb": "^7.1.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.18"
  }
}
